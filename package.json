{
    "workspaces": [
        "backend",
        "frontend",
        "shared"
    ],
    "scripts": {
        "build": "npm --prefix backend run build && npm --prefix frontend run build",
        "test": "npm run backend:test:local",
        "backend:build": "npm --prefix backend run build",
        "backend:deploy": "npm --prefix backend run deploy",
        "backend:invoke:docker": "npm --prefix backend run invoke:docker",
        "backend:start:docker": "npm --prefix backend run start",
        "backend:test:local": "npm --prefix backend run test:local",
        "frontend:build": "npm --prefix frontend run build",
        "frontend:dev": "npm --prefix frontend run dev",
        "typecheck:backend": "npm run typecheck -w backend",
        "typecheck:frontend": "npm run typecheck -w frontend",
        "test:backend": "npm test -w backend",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "validate": "npm run format && npm run lint",
        "pin-actions": "pin-github-action .github/workflows/deploy.yml",
        "prepare": "node -e \"if (process.env.CI !== 'true') { try { require('child_process').execSync('npx husky', {stdio: 'inherit'}); } catch (e) { process.exit(0); } }\""
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "eslint": "10.3.0",
        "eslint-config-prettier": "10.1.8",
        "globals": "17.6.0",
        "prettier": "3.8.3",
        "typescript-eslint": "8.59.2",
        "pin-github-action": "^3.4.0",
        "lint-staged": "^15.2.0",
        "husky": "^9.0.0"
    },
    "lint-staged": {
        ".github/workflows/*.{yml,yaml}": [
            "pin-github-action"
        ],
        "backend/**/*.{js,ts}": [
            "npm run lint --prefix backend -- --fix",
            "prettier --write"
        ],
        "frontend/**/*.{js,jsx,ts,tsx}": [
            "npm run lint --prefix frontend -- --fix",
            "prettier --write"
        ]
    }
}
